generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // UUID from Supabase Auth
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts   Account[]
  categories Category[]
  budgets    Budget[]

  @@map("users")
}

model Account {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  bankName  String?  @map("bank_name")
  currency  String   @default("EUR")
  color     String   @default("#6366f1")
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

model Category {
  id        String       @id @default(cuid())
  userId    String?      @map("user_id") // null = categoría del sistema
  name      String
  icon      String       @default("circle")
  color     String       @default("#6366f1")
  type      CategoryType @default(BOTH)
  isDefault Boolean      @default(false) @map("is_default")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id             String            @id @default(cuid())
  accountId      String            @map("account_id")
  categoryId     String?           @map("category_id")
  amount         Decimal           @db.Decimal(10, 2)
  type           TransactionType
  description    String
  rawDescription String?           @map("raw_description")
  date           DateTime
  notes          String?
  source         TransactionSource @default(MANUAL)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model Budget {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  categoryId String       @map("category_id")
  amount     Decimal      @db.Decimal(10, 2)
  period     BudgetPeriod @default(MONTHLY)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period])
  @@map("budgets")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  CSV_IMPORT
  MANUAL
}

enum CategoryType {
  INCOME
  EXPENSE
  BOTH
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}
